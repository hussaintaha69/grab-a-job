# Supabase project settings -> API
# Public values, safe to expose to the browser (used for Google sign-in)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Same URL, kept as a server-only name for the admin client
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Secret — never expose this to the browser or commit it.
# Only used by /api/save-job to look up which user a bookmarklet token belongs to.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
